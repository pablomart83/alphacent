{
  "name": "alphacent",
  "version": "1.0.0",
  "description": "AlphaCent Autonomous Trading Platform",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "source venv/bin/activate && python run_backend.py",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "npm run dev:all"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
